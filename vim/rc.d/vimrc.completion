set wildmenu		"improve command completion
set wildchar=<tab>	"key to start command completion
set wildmode=list:longest,full	" like as zsh
set history=10000	"number of history for completion

" Use neocomplcache
let s:config_dir = stdpath('config')
execute 'source ' . fnameescape(s:config_dir . '/rc.d/vimrc.completion.neocomplcache')