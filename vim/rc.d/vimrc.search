set wrapscan    " Search wraps around the end of the file
set ignorecase  " Ignore case in search patterns
set smartcase   " Override ignorecase when search pattern contains uppercase
set incsearch   " Show incremental search matches
set hlsearch    " Highlight search matches

" Clear search highlighting with <Esc><Esc>
nnoremap <Esc><Esc> :nohlsearch<CR>
