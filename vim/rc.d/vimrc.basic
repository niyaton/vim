set clipboard+=unnamed " Use clipboard of OS

" enable mouse on terminal.
set mouse=a
if !has('nvim')
  set backspace=indent,eol,start
  set ttymouse=xterm2
  set guioptions+=a
endif

command! Ev edit $MYVIMRC	" edit .vimrc
command! Rv source $MYVIMRC	" reload .vimrc

filetype plugin on " turn on file type
